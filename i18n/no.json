    "about":{
        "title": "Om La Luna",
        "p": "Vi er en norsk restaurant som har drever her i over 20 år, og kjøkkenet vårt er hovedsakelig nordisk. Ta gjerne en kikk på menyen vår, så ønsker vi alle en hyggelig tur innom oss her på La Luna."
    }, 

    "event": {
        "title": "Arrangement",
        "p": "Gjennom helle året holder vi mange ulike arrangement."
    },

    "quiz": {
        "title": "Quiz",
        "p": "Vi arrangerer quiz på tirsdager og alle er velkommen."
    },

    "golf": {
        "title": "Golf",
        "p":"Her på La Luna er vi veldig glad i å spille golf, så om du letter etter noen å spille med er det bare å melde seg på å bli med.",
        "button": "Les Mer"
    },

    "footer": {
        "address": "C. de la Garza 28, \n03189 Orihuela, \nAlicante, Spania",
        "opening": {
            "title": "Åpningstider",
            "1": "Mandag Stengt",
            "2": "Tirsdag til Søndag \nkl 12:00 - 23:00",
            "3": "Kjøkkenet stenger \nkl 22:00"
        }
    },

    "golfOverlay": {
        "h3": "Golf",
        "p": "Her på La Luna Golf spiller vi hver onsdag, og alle HCP-er er velkommen. \n\nHer er vi en gruppe Nordmenn som koser oss og bygger et sosialt nettverk sammen. Når vi er ferdige å spille tar vi turen opp på La Luna på middag sammen, og ta gjerne med en ekstra gjest på middagen om dere vil det. \n\nHøres dette kjekt ut så er det bare å ta kontakt ved å ringe direkte til Irene på +34 650 049 726 eller kom innom restauranten en tur. Påmelding og betaling skjer senest søndagen før vi spiller."
    },

    "eventOverlay": {
        "h3": "Arrangement",
        "p": "Gjennom helle året har vi mange ulike arrangement, og noen eksempler på arrangement vi har hatt i tidligere år er rekeaften, fårikål dagene, 17 mai og julaften. For framtidige arrangement som vi holder så er det bare å holde et øye på Facebook der all informasjon om ulike arrangement blir oppdatert. \n\nHar du en spesiell anledning som skal feires som for eksempel bursdag, bryllup, eller en har en anledning der mange skal samles så er det bare å ta kontakt på telefon +34 650 049 726 eller kom innom en tur på forhånd. Vi elsker å stelle i stand en kjekk dag for gjestene våre."
    },

    "quizOverlay": {
        "h3": "Quiz",
        "p": "Vi arrangerer Quiz hver tirsdag klokken 20:00. Kom gjerne innom i 18-19:00 tiden for å få noe mat før vi starter. \n\nPåmeldingen skjer når dere kommer, rett før vi starter og koser 3€ per person, all intekt fra quizen går til veldedighet."
    },

    "podcastPageTitle": "Podkast",

    "podcastText": "En podkast  laget av nordmenn for nordmenn. Vi snakker om alt mulig informasjon som kan være kjekt å vite om livet her i Spania..",

